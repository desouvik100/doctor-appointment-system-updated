# HealthSync Backend — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# ── MongoDB ────────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/doctor_appointment?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_jwt_secret_minimum_64_characters_here

# ── Server ─────────────────────────────────────────────────────────────────
PORT=5005
NODE_ENV=development

# ── URLs ───────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:5005
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001

# ── Razorpay (get from https://dashboard.razorpay.com/app/keys) ────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_MODE=test
USE_RAZORPAY_PAYMENTS=true
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Stripe (legacy, optional) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ── Payment Config ─────────────────────────────────────────────────────────
CURRENCY=INR
PLATFORM_FEE_PERCENTAGE=5
GST_PERCENTAGE=0

# ── Email (Gmail App Password) ─────────────────────────────────────────────
# Enable 2FA on Gmail, then create App Password at myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password
ADMIN_EMAIL=your_admin_email@gmail.com

# ── Resend (optional, for transactional emails) ────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=HealthSync <no-reply@healthsyncpro.in>

# ── AI / Gemini ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
AI_PROVIDER=gemini

# ── Google OAuth & Calendar ────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5005/api/google/callback
GOOGLE_REFRESH_TOKEN=your_google_refresh_token

# ── Timezone ───────────────────────────────────────────────────────────────
TIMEZONE=Asia/Kolkata

# ── SMS / MSG91 ────────────────────────────────────────────────────────────
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=HLTHSN

# ── Twilio (WhatsApp + SMS backup) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── WhatsApp Business API (Meta) ───────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_VERIFY_TOKEN=healthsync_whatsapp_verify

# ── Cloudinary (medical file storage) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Test Mode ──────────────────────────────────────────────────────────────
TEST_APPOINTMENT=false
